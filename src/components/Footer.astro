---
import GitHub from '../icons/GitHub.astro';
import X from '../icons/X.astro';
import Bluesky from '../icons/Bluesky.astro';
import Email from '../icons/Email.astro';
import RSS from '../icons/RSS.astro';
const today = new Date();
---

<footer
  class="mt-auto flex items-center justify-center gap-4 bg-[#0a0a0b] pb-12 pt-10 text-sm text-gray-400"
>
  <div class="flex flex-col items-center gap-5">
    &copy; {today.getFullYear()} Max Shen. All rights reserved.
    <div class="flex gap-5">
      <a
        href="https://github.com/m4xshen"
        class="fill-gray-400 transition duration-300 hover:fill-gray-100"
        aria-label="GitHub"
      >
        <GitHub />
      </a>
      <a
        href="https://x.com/m4xshen"
        class="fill-gray-400 transition duration-300 hover:fill-gray-100"
        aria-label="X"
      >
        <X />
      </a>
      <a
        href="https://bsky.app/profile/m4xshen.dev"
        class="fill-gray-400 transition duration-300 hover:fill-gray-100"
        aria-label="Bluesky"
      >
        <Bluesky />
      </a>
      <a
        href="mailto:m4xshen@gmail.com"
        class="fill-gray-400 transition duration-300 hover:fill-gray-100"
        aria-label="Email"
      >
        <Email />
      </a>
      <a
        href="/rss.xml"
        class="fill-gray-400 transition duration-300 hover:fill-gray-100"
        aria-label="RSS"
      >
        <RSS />
      </a>
    </div>
  </div>
</footer>
